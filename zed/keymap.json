// Zed keymap
// https://zed.dev/docs/key-bindings
//
// attemp at getting some of my nvim keybinds here.
[
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "alt-k": "editor::MoveLineUp",
      "alt-j": "editor::MoveLineDown",
      "space g b": "editor::CopyPermalinkToLine",
    },
  },
  {
    // motions / jumps
    "context": "vim_mode == normal",
    "bindings": {
      "g r": "editor::FindAllReferences",
      "space j f": "editor::RevealInFileManager",
      "[ h": "editor::GoToPreviousHunk",
      "] h": "editor::GoToHunk",
      "space b o": "workspace::CloseInactiveTabsAndPanes",
      "alt-h": "vim::FirstNonWhitespace",
      "alt-l": "vim::EndOfLine"
    },
  },
  {
    // visual select objects
    "context": "vim_operator == a || vim_operator == i",
    "bindings": {
      "q": "vim::AnyQuotes",
      "b": "vim::AnyBrackets",
      "g": "vim::EntireFile",
    },
  },
  {
    // global window/buffer/pane control
    "context": "!Editor || vim_mode == normal",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "space /": "pane::DeploySearch",
      "space space": "file_finder::Toggle",
      "space e": "workspace::ToggleRightDock",
      "space backspace": "pane::CloseActiveItem",
      "shift-h": "pane::ActivatePreviousItem",
      "shift-l": "pane::ActivateNextItem",
    },
  },
]
